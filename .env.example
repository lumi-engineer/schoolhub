# Database — use Neon, Vercel Postgres, or local PostgreSQL
# Neon example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/schoolhub"

# Required in production (generate a long random string)
JWT_SECRET="change-this-to-a-long-random-secret"

# Optional — only set when using custom domain wildcard subdomains (e.g. schoolhub.app)
# ROOT_DOMAIN="schoolhub.app"
